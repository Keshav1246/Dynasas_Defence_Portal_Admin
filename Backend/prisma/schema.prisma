generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Media {
  id           Int       @id @default(autoincrement())
  fileName     String
  originalName String
  fileUrl      String
  fileType     String
  size         Int
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
}

model Partner {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?
  logo         String?
  website      String?
  status       PartnerStatus @default(ACTIVE)
  isDeleted    Boolean       @default(false)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  displayOrder Int           @default(0)
}

model Inquiry {
  id           Int           @id @default(autoincrement())
  fullName     String
  email        String
  phone        String?
  organization String?
  subject      String
  message      String
  status       InquiryStatus @default(NEW)
  isDeleted    Boolean       @default(false)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  inquiryType  InquiryType   @default(CONTACT)
  assignedTeam String?
  internalNote String?
  emailError   String?
  emailSent    Boolean       @default(false)
  emailStatus  String?       @default("PENDING")
  sentAt       DateTime?
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  action     String
  entityType String
  entityId   String?
  details    String?
  createdAt  DateTime @default(now())
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  password        String
  createdAt       DateTime         @default(now())
  lastLogin       DateTime?
  status          UserStatus       @default(ACTIVE)
  updatedAt       DateTime         @default(now()) @updatedAt
  invitationsSent UserInvitation[] @relation("InvitedBy")
}

model CompanyProfile {
  id                     String             @id @default(uuid())
  companyName            String
  overview               String
  defenseContractsPhone  String?
  foundedYear            String?
  generalEmail           String?
  headquarters           String?
  logo                   String?
  longTermGoals          String?
  mailingAddress         String?
  mainPhone              String?
  missionStatement       String?
  missionTitle           String?
  registrationNumber     String?
  securityEmail          String?
  visionStatement        String?
  visionTitle            String?
  website                String?
  visionFuturePriorities String[]           @default([])
  city                   String?
  state                  String?
  country                String?
  postalCode             String?
  fullAddress            String?
  hrEmail                String?
  enquiryEmail           String?
  partnersEmail          String?
  technicalEmail         String?
  statistics             CompanyStatistic[]
  missionPillars         MissionPillar[]
}

model CompanyStatistic {
  id               String         @id @default(uuid())
  label            String
  value            String
  displayOrder     Int            @default(0)
  companyProfileId String
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
}

model MissionPillar {
  id               String         @id @default(uuid())
  text             String
  displayOrder     Int            @default(0)
  companyProfileId String
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
}

model HomepageContent {
  id                         String   @id @default(uuid())
  heroTitle                  String
  heroSubtitle               String
  ctaText                    String
  ctaLink                    String
  heroImage                  String
  secondaryCtaLink           String?
  secondaryCtaText           String?
  sectionOrder               String[] @default(["hero", "services", "statistics"])
  servicesSectionDescription String?
  servicesSectionTitle       String?
  statisticsSectionTitle     String?
  heroDescription            String   @default("")
  partnersButtonLink         String?
  partnersButtonText         String?
  partnersSectionDescription String?
  partnersSectionLabel       String?
  partnersSectionTitle       String?
  trustBarItems              String[] @default([])
}

model ServicesPageContent {
  id                     String  @id @default(uuid())
  heroLabel              String?
  heroTitle              String?
  heroDescription        String?
  servicesNavigatorTitle String?
}

model FooterContent {
  id                String   @id @default(uuid())
  address           String
  phone             String
  email             String
  companyLinks      String[]
  footerDescription String?
  footerTagline     String?
  legalLinks        String[]
  resourceLinks     String[]
  solutionLinks     String[]
  city              String?
  state             String?
  country           String?
  postalCode        String?
  fullAddress       String?
}

model Service {
  id             String   @id @default(uuid())
  title          String
  description    String
  image          String?
  status         String   @default("published")
  displayOrder   Int      @default(0)
  createdAt      DateTime @default(now())
  ctaLink        String?
  ctaText        String?
  features       String[]
  isActive       Boolean  @default(true)
  subtitle       String?
  hasSubservices Boolean  @default(false)
  subservices    Json?
}

model WebsiteAnalytics {
  id              Int      @id @default(autoincrement())
  sessionId       String
  visitorId       String
  pagePath        String
  durationSeconds Int      @default(0)
  bounced         Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model UserInvitation {
  id              String   @id @default(uuid())
  email           String   @unique
  name            String
  invitationToken String   @unique
  expiresAt       DateTime
  status          String   @default("PENDING")
  invitedById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  invitedBy       User     @relation("InvitedBy", fields: [invitedById], references: [id])
}

model Settings {
  id              String   @id @default(uuid())
  primaryColor    String?
  accentColor     String?
  backgroundDark  String?
  textColor       String?
  primaryLogo     String?
  darkLogo        String?
  favicon         String?
  headingFont     String?
  bodyFont        String?
  linkedinUrl     String?
  twitterUrl      String?
  youtubeUrl      String?
  facebookUrl     String?
  instagramUrl    String?
  portalName      String?
  siteName        String?
  siteDescription String?
  supportEmail    String?
  supportPhone    String?
  defaultLanguage String?  @default("English")
  timezone        String?  @default("Asia/Kolkata")
  maintenanceMode Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  seoDescription  String?
  seoKeywords     String?
  seoOgImage      String?
  seoTitle        String?
  seoTwitterImage String?
}

model Office {
  id           String   @id @default(uuid())
  officeName   String
  officeType   String?
  city         String?
  state        String?
  country      String?
  postalCode   String?
  fullAddress  String
  phone        String?
  email        String?
  latitude     Float?
  longitude    Float?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum InquiryType {
  CONTACT
  DEMO_REQUEST
  QUOTE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}
