generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Media {
  id           Int       @id @default(autoincrement())
  fileName     String
  originalName String
  fileUrl      String
  fileType     String
  size         Int
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

model Partner {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  logo        String?
  website     String?
  category    String?
  status      PartnerStatus @default(ACTIVE)
  isDeleted   Boolean       @default(false)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum InquiryType {
  CONTACT
  DEMO_REQUEST
  QUOTE
}

model Inquiry {
  id              Int           @id @default(autoincrement())
  fullName        String
  email           String
  phone           String?
  organization    String?
  subject         String
  message         String
  inquiryType     InquiryType   @default(CONTACT)
  status          InquiryStatus @default(NEW)
  assignedAdminId String?
  assignedAdmin   User?         @relation(fields: [assignedAdminId], references: [id])
  isDeleted       Boolean       @default(false)
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}


enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  CONTENT_MANAGER
  VIEWER
}

model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  password          String
  role              AdminRole @default(ADMIN)
  status            UserStatus @default(ACTIVE)
  lastLogin         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  assignedInquiries Inquiry[]
  invitationsSent   UserInvitation[] @relation("InvitedBy")
}

model CompanyProfile {
  id           String @id @default(uuid())
  companyName  String
  overview     String
  mission      String
  vision       String
  contactEmail String
  phone        String
  address      String
}

model HomepageContent {
  id           String @id @default(uuid())
  heroTitle    String
  heroSubtitle String
  ctaText      String
  ctaLink      String
  heroImage    String
}

model FooterContent {
  id      String @id @default(uuid())
  address String
  phone   String
  email   String
}

model Service {
  id           String   @id @default(uuid())
  title        String
  description  String
  image        String?
  status       String   @default("published")
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
}

model WebsiteAnalytics {
  id              Int      @id @default(autoincrement())
  sessionId       String
  visitorId       String
  pagePath        String
  durationSeconds Int      @default(0)
  bounced         Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model UserInvitation {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String
  role            AdminRole @default(ADMIN)
  invitationToken String    @unique
  expiresAt       DateTime
  status          String    @default("PENDING") // PENDING, ACCEPTED, CANCELLED
  invitedById     String
  invitedBy       User      @relation("InvitedBy", fields: [invitedById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model RolePermissions {
  id            String    @id @default(uuid())
  role          AdminRole @unique
  
  // Permissions boolean fields
  dashboardAccess     Boolean @default(false)
  homepageManage      Boolean @default(false)
  servicesView        Boolean @default(false)
  servicesEdit        Boolean @default(false)
  servicesDelete      Boolean @default(false)
  mediaUpload         Boolean @default(false)
  mediaDelete         Boolean @default(false)
  inquiriesView       Boolean @default(false)
  inquiriesManage     Boolean @default(false)
  partnersManage      Boolean @default(false)
  analyticsView       Boolean @default(false)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
