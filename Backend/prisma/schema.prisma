generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Media {
  id           Int       @id @default(autoincrement())
  fileName     String
  originalName String
  fileUrl      String
  fileType     String
  size         Int
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
}

model Partner {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  logo        String?
  website     String?
  status      PartnerStatus @default(ACTIVE)
  displayOrder Int          @default(0)
  isDeleted   Boolean       @default(false)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum InquiryType {
  CONTACT
  DEMO_REQUEST
  QUOTE
}

model Inquiry {
  id              Int           @id @default(autoincrement())
  fullName        String
  email           String
  phone           String?
  organization    String?
  subject         String
  message         String
  inquiryType     InquiryType   @default(CONTACT)
  status          InquiryStatus @default(NEW)
  assignedTeam    String?
  internalNote    String?
  isDeleted       Boolean       @default(false)
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  emailSent       Boolean       @default(false)
  sentAt          DateTime?
  emailStatus     String?       @default("PENDING") // PENDING, SENT, FAILED
  emailError      String?
}


enum UserStatus {
  ACTIVE
  INACTIVE
}



model ActivityLog {
  id         Int      @id @default(autoincrement())
  action     String
  entityType String
  entityId   String?
  details    String?
  createdAt  DateTime @default(now())
}

model User {
  id                String    @id @default(uuid())
  name              String
  email             String    @unique
  password          String
  status            UserStatus @default(ACTIVE)
  lastLogin         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  invitationsSent   UserInvitation[] @relation("InvitedBy")
}

model CompanyProfile {
  id          String @id @default(uuid())
  companyName String
  overview    String

  // New About Us fields
  foundedYear        String?
  headquarters       String?
  registrationNumber String?
  logo               String?

  // New Mission fields
  missionTitle     String?
  missionStatement String?

  // New Vision fields
  visionTitle            String?
  visionStatement        String?
  longTermGoals          String?
  visionFuturePriorities String[] @default([])

  // New Contact fields
  generalEmail          String?
  securityEmail         String?
  hrEmail               String?
  enquiryEmail          String?
  partnersEmail         String?
  technicalEmail        String?
  mainPhone             String?
  defenseContractsPhone String?
  mailingAddress        String?
  city                  String?
  state                 String?
  country               String?
  postalCode            String?
  fullAddress           String?
  website               String?

  // Relations
  statistics     CompanyStatistic[]
  missionPillars MissionPillar[]
}

model CompanyStatistic {
  id               String         @id @default(uuid())
  label            String
  value            String
  displayOrder     Int            @default(0)
  companyProfileId String
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
}

model MissionPillar {
  id               String         @id @default(uuid())
  text             String
  displayOrder     Int            @default(0)
  companyProfileId String
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
}

model HomepageContent {
  id           String @id @default(uuid())
  heroTitle    String
  heroSubtitle String
  heroDescription String @default("")
  ctaText      String
  ctaLink      String
  heroImage    String

  secondaryCtaText           String?
  secondaryCtaLink           String?
  servicesSectionTitle       String?
  servicesSectionDescription String?
  statisticsSectionTitle     String?

  sectionOrder               String[] @default(["hero", "services", "statistics"])
  trustBarItems              String[] @default([])

  partnersSectionLabel       String?
  partnersSectionTitle       String?
  partnersSectionDescription String?
  partnersButtonText         String?
  partnersButtonLink         String?
}

model ServicesPageContent {
  id                     String  @id @default(uuid())
  heroLabel              String?
  heroTitle              String?
  heroDescription        String?
  servicesNavigatorTitle String?
}

model FooterContent {
  id      String @id @default(uuid())
  address String
  city        String?
  state       String?
  country     String?
  postalCode  String?
  fullAddress String?
  phone   String
  email   String

  footerTagline     String?
  footerDescription String?

  companyLinks  String[]
  solutionLinks String[]
  resourceLinks String[]
  legalLinks    String[]
}

model Service {
  id           String   @id @default(uuid())
  title        String
  subtitle     String?
  description  String
  image        String?
  features     String[]
  hasSubservices Boolean  @default(false)
  subservices    Json?
  ctaText      String?
  ctaLink      String?
  status       String   @default("published")
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
}

model WebsiteAnalytics {
  id              Int      @id @default(autoincrement())
  sessionId       String
  visitorId       String
  pagePath        String
  durationSeconds Int      @default(0)
  bounced         Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model UserInvitation {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String
  invitationToken String    @unique
  expiresAt       DateTime
  status          String    @default("PENDING") // PENDING, ACCEPTED, CANCELLED
  invitedById     String
  invitedBy       User      @relation("InvitedBy", fields: [invitedById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}



model Settings {
  id String @id @default(uuid())

  // Branding
  primaryColor   String?
  accentColor    String?
  backgroundDark String?
  textColor      String?

  primaryLogo String?
  darkLogo    String?
  favicon     String?

  headingFont String?
  bodyFont    String?

  // Social Media
  linkedinUrl  String?
  twitterUrl   String?
  youtubeUrl   String?
  facebookUrl  String?
  instagramUrl String?

  // Site Settings
  portalName      String?
  siteName        String?
  siteDescription String?
  supportEmail    String?
  supportPhone    String?

  defaultLanguage String? @default("English")
  timezone        String? @default("Asia/Kolkata")
  maintenanceMode Boolean @default(false)

  // SEO Settings
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?
  seoOgImage      String?
  seoTwitterImage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
